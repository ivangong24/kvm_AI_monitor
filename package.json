{
  "name": "kvm-ai-monitor",
  "version": "0.8.0",
  "private": true,
  "description": "A KVM-native AI subscription usage wallpaper for GL.iNet Comet Pro",
  "type": "module",
  "bin": {
    "kvm-ai-monitor": "bin/kvm-ai-monitor.mjs"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "setup": "node bin/kvm-ai-monitor.mjs setup",
    "test": "node --test",
    "kvm:configure": "node scripts/run-script.mjs kvm:configure",
    "kvm:agent:install": "node scripts/run-script.mjs kvm:agent:install",
    "kvm:agent:uninstall": "node scripts/run-script.mjs kvm:agent:uninstall",
    "helper:install": "node scripts/run-script.mjs helper:install",
    "helper:uninstall": "node scripts/run-script.mjs helper:uninstall",
    "helper:install:win": "node scripts/run-script.mjs helper:install",
    "helper:uninstall:win": "node scripts/run-script.mjs helper:uninstall",
    "helper:status": "node scripts/run-script.mjs helper:status",
    "helper:hooks": "node scripts/run-script.mjs helper:hooks",
    "helper:test": "node scripts/run-script.mjs helper:test"
  }
}
